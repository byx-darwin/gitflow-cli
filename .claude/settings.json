{
  "hooks": {
    "Stop": [
      {
        "hooks": [
          {
            "command": "bash \"$(git rev-parse --show-toplevel 2>/dev/null || pwd)/hooks/auto-report-bug.sh\"",
            "type": "command"
          }
        ],
        "matcher": "gitflow"
      },
      {
        "hooks": [
          {
            "command": "bash \"$(git rev-parse --show-toplevel 2>/dev/null || pwd)/hooks/sync-readme-check.sh\"",
            "type": "command"
          }
        ],
        "matcher": ""
      }
    ]
  }
}
