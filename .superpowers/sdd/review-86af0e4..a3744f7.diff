+fn test_should_include_mandatory_phase4_skills_in_fast_mode() {
+    let md = skill_md();
+    let Some(fast_section) = md.split("快速模式 - 必须调用的 Skills 清单").nth(1) else {
+        panic!(
+            "Fast mode skills section '快速模式 - 必须调用的 Skills 清单' must exist in SKILL.md"
+        );
